pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: gcloud
    image: google/cloud-sdk:latest
    command: ["cat"]
    tty: true
'''
        }
    }
    environment {
        PROJECT = credentials('project_id')
        REPO_PATH = credentials('repo_path')
        CLUSTER = credentials('cluster_name')
        ZONE = credentials('cluster_zone')
    }
    tools {
        maven 'maven'
    }
    stages {
        stage('Build & Push with Jib') {
            steps {
                dir('BinaryCalculatorWebapp') {
                    // This combines building and pushing to bypass GKE scope issues
                    sh "mvn compile jib:build -DskipTests -Djib.to.image=us-central1-docker.pkg.dev/${PROJECT}/sofe3980u/binarycalculatorwebapp:latest"
                }
            }
        }
        stage('Deploy to GKE') {
            steps {
                container('gcloud') {
                    sh "gcloud container clusters get-credentials ${CLUSTER} --zone ${ZONE} --project ${PROJECT}"
                    script {
                        try {
                            sh "kubectl delete deployment binarycalculator-deployment"
                        } catch (e) {
                            echo "Deployment not found, creating fresh."
                        }
                    }
                    sh "kubectl create deployment binarycalculator-deployment --image=us-central1-docker.pkg.dev/${PROJECT}/sofe3980u/binarycalculatorwebapp:latest --port=8080"
                    sh "kubectl expose deployment binarycalculator-deployment --type=LoadBalancer --name=binarycalculator-service || true"
                }
            }
        }
    }
}