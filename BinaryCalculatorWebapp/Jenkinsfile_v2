pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: gcloud
    image: google/cloud-sdk:latest
    command: ["cat"]
    tty: true
'''
        }
    }
    environment {
        PROJECT = credentials('project_id')
        REPO_PATH = credentials('repo_path')
        CLUSTER = credentials('cluster_name')
        ZONE = credentials('cluster_zone')
        IMAGE = "${REPO_PATH}/binarycalculatorwebapp:latest"
    }
    tools {
        maven 'maven'
    }
    stages {
        stage('Build') {
            steps {
                dir('BinaryCalculatorWebapp') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }
        stage('Push to Registry') {
            steps {
                container('gcloud') {
                    dir('BinaryCalculatorWebapp') {
                        sh "gcloud config set project ${PROJECT}"
                        // Using --no-source avoids the "Forbidden Bucket" error
                        sh "gcloud builds submit --project=${PROJECT} --tag ${IMAGE} --no-source ."
                    }
                }
            }
        }
        stage('Deploy') {
            steps {
                container('gcloud') {
                    sh "gcloud container clusters get-credentials ${CLUSTER} --zone ${ZONE} --project ${PROJECT}"
                    sh "kubectl apply -f BinaryCalculatorWebapp/deployment.yaml || (kubectl create deployment binarycalculator --image=${IMAGE} && kubectl expose deployment binarycalculator --type=LoadBalancer --port=8080)"
                }
            }
        }
    }
}