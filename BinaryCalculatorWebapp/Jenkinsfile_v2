pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: gcloud
    image: google/cloud-sdk:latest
    command: ["cat"]
    tty: true
'''
        }
    }
    environment {
        PROJECT = credentials('project_id')
        REPO_PATH = credentials('repo_path')
        CLUSTER = credentials('cluster_name')
        ZONE = credentials('cluster_zone')
        IMAGE = "${REPO_PATH}/binarycalculatorwebapp:latest"
    }
    tools {
        maven 'maven'
    }
    stages {
        stage('Build & Test') {
            steps {
                // Ensure we are in the correct directory for Maven
                dir('BinaryCalculatorWebapp') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }
        stage('Push to Registry') {
            steps {
                container('gcloud') {
                    dir('BinaryCalculatorWebapp') {
                        sh "gcloud config set project ${PROJECT}"
                        sh "gcloud auth configure-docker us-central1-docker.pkg.dev --quiet"
                        sh "gcloud builds submit --project=${PROJECT} --tag ${IMAGE} ."
                    }
                }
            }
        }
        stage('Deploy to GKE') {
            steps {
                container('gcloud') {
                    sh "gcloud container clusters get-credentials ${CLUSTER} --zone ${ZONE} --project ${PROJECT}"
                    script {
                        try {
                            sh "kubectl delete deployment binarycalculator-deployment"
                        } catch (e) {
                            echo "Deployment not found, creating fresh."
                        }
                    }
                    sh "kubectl create deployment binarycalculator-deployment --image=${IMAGE} --port=8080"
                    sh "kubectl expose deployment binarycalculator-deployment --type=LoadBalancer --name=binarycalculator-service || true"
                }
            }
        }
    }
}